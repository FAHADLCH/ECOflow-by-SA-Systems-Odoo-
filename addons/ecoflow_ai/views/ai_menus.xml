<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Server actions that (re)generate AI data, reachable from menu items -->
    <record id="action_generate_forecast_srv" model="ir.actions.server">
        <field name="name">Generate Forecast</field>
        <field name="model_id" ref="model_ecoflow_ai_forecast"/>
        <field name="state">code</field>
        <field name="code">action = model.action_generate_forecast()</field>
    </record>
    <record id="action_generate_predictions_srv" model="ir.actions.server">
        <field name="name">Predict Fill Levels</field>
        <field name="model_id" ref="model_ecoflow_bin_prediction"/>
        <field name="state">code</field>
        <field name="code">action = model.action_generate_predictions()</field>
    </record>
    <record id="action_refresh_insights_srv" model="ir.actions.server">
        <field name="name">Refresh Insights</field>
        <field name="model_id" ref="model_ecoflow_ai_insight"/>
        <field name="state">code</field>
        <field name="code">action = model.action_refresh_insights()</field>
    </record>

    <!-- AI Intelligence top section under the ECOFLOW root -->
    <menuitem id="menu_ecoflow_ai_root"
              name="AI Intelligence"
              parent="ecoflow_base.menu_ecoflow_root"
              sequence="2"
              groups="ecoflow_base.group_ecoflow_user"/>

    <menuitem id="menu_ai_insights"
              name="AI Insights"
              parent="menu_ecoflow_ai_root"
              action="action_ai_insight"
              sequence="10"/>
    <menuitem id="menu_ai_forecast"
              name="Demand Forecast"
              parent="menu_ecoflow_ai_root"
              action="action_ai_forecast"
              sequence="20"/>
    <menuitem id="menu_bin_prediction"
              name="Predictive Bin Fill"
              parent="menu_ecoflow_ai_root"
              action="action_bin_prediction"
              sequence="30"/>

    <!-- Generation actions grouped together -->
    <menuitem id="menu_ai_generate"
              name="Run / Refresh"
              parent="menu_ecoflow_ai_root"
              sequence="90"
              groups="ecoflow_base.group_ecoflow_dispatcher"/>
    <menuitem id="menu_ai_refresh_insights"
              name="Refresh Insights"
              parent="menu_ai_generate"
              action="action_refresh_insights_srv"
              sequence="10"/>
    <menuitem id="menu_ai_generate_forecast"
              name="Generate Forecast"
              parent="menu_ai_generate"
              action="action_generate_forecast_srv"
              sequence="20"/>
    <menuitem id="menu_ai_generate_predictions"
              name="Predict Fill Levels"
              parent="menu_ai_generate"
              action="action_generate_predictions_srv"
              sequence="30"/>
</odoo>
