<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Kanban: the AI Insights board -->
    <record id="view_ai_insight_kanban" model="ir.ui.view">
        <field name="name">ecoflow.ai.insight.kanban</field>
        <field name="model">ecoflow.ai.insight</field>
        <field name="arch" type="xml">
            <kanban class="o_ecoflow_insight_kanban" default_group_by="severity"
                    records_draggable="0" group_create="false">
                <field name="severity"/>
                <field name="severity_rank"/>
                <field name="category"/>
                <field name="icon"/>
                <field name="impact_label"/>
                <field name="confidence"/>
                <field name="action_xmlid"/>
                <templates>
                    <t t-name="card">
                        <div t-attf-class="o_ecoflow_insight sev_#{record.severity.raw_value}">
                            <div class="o_insight_head">
                                <i t-attf-class="fa #{record.icon.value} o_insight_icon" title="Insight category"/>
                                <span class="o_insight_title">
                                    <field name="name"/>
                                </span>
                            </div>
                            <div class="o_insight_body">
                                <field name="description"/>
                            </div>
                            <div class="o_insight_reco" t-if="record.recommendation.raw_value">
                                <strong>Action: </strong><field name="recommendation"/>
                            </div>
                            <div class="o_insight_foot">
                                <span class="badge o_insight_cat">
                                    <field name="category"/>
                                </span>
                                <span class="o_insight_impact" t-if="record.impact_label.raw_value">
                                    <i class="fa fa-bolt" title="Estimated impact"/> <field name="impact_label"/>
                                </span>
                                <span class="o_insight_conf">
                                    <i class="fa fa-shield" title="Confidence"/> <field name="confidence"/>% conf.
                                </span>
                            </div>
                            <button t-if="record.action_xmlid.raw_value"
                                    name="action_open_target" type="object"
                                    class="btn btn-sm btn-secondary o_insight_btn">
                                Open <i class="fa fa-arrow-right" title="Open"/>
                            </button>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_ai_insight_list" model="ir.ui.view">
        <field name="name">ecoflow.ai.insight.list</field>
        <field name="model">ecoflow.ai.insight</field>
        <field name="arch" type="xml">
            <list decoration-danger="severity=='critical'"
                  decoration-warning="severity=='warning'"
                  decoration-success="severity=='opportunity'">
                <field name="severity"/>
                <field name="category"/>
                <field name="name"/>
                <field name="impact_label"/>
                <field name="confidence"/>
                <field name="generated_on"/>
            </list>
        </field>
    </record>

    <record id="view_ai_insight_form" model="ir.ui.view">
        <field name="name">ecoflow.ai.insight.form</field>
        <field name="model">ecoflow.ai.insight</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="severity"/>
                            <field name="category"/>
                            <field name="confidence"/>
                        </group>
                        <group>
                            <field name="impact_label"/>
                            <field name="generated_on"/>
                            <field name="action_xmlid"/>
                        </group>
                    </group>
                    <group string="Analysis">
                        <field name="description" nolabel="1"/>
                    </group>
                    <group string="Recommended Action">
                        <field name="recommendation" nolabel="1"/>
                    </group>
                    <footer>
                        <button name="action_open_target" type="object"
                                string="Open Related Records" class="btn-primary"
                                invisible="not action_xmlid"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ai_insight" model="ir.actions.act_window">
        <field name="name">AI Insights</field>
        <field name="res_model">ecoflow.ai.insight</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_group_severity': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No insights yet</p>
            <p>Click <b>Refresh Insights</b> to let ECOFLOW AI analyse your
               operations and surface recommendations.</p>
        </field>
    </record>
</odoo>
