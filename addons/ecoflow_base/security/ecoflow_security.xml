<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_ecoflow" model="ir.module.category">
            <field name="name">ECOFLOW</field>
            <field name="description">Environmental Operations ERP</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_ecoflow_user" model="res.groups">
            <field name="name">ECOFLOW / Operator</field>
            <field name="category_id" ref="module_category_ecoflow"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_ecoflow_dispatcher" model="res.groups">
            <field name="name">ECOFLOW / Dispatcher</field>
            <field name="category_id" ref="module_category_ecoflow"/>
            <field name="implied_ids" eval="[(4, ref('group_ecoflow_user'))]"/>
        </record>

        <record id="group_ecoflow_manager" model="res.groups">
            <field name="name">ECOFLOW / Manager</field>
            <field name="category_id" ref="module_category_ecoflow"/>
            <field name="implied_ids" eval="[(4, ref('group_ecoflow_dispatcher'))]"/>
        </record>

        <!-- Give the administrator full ECOFLOW access out of the box -->
        <record id="base.user_admin" model="res.users">
            <field name="groups_id" eval="[(4, ref('group_ecoflow_manager'))]"/>
        </record>
    </data>
</odoo>
