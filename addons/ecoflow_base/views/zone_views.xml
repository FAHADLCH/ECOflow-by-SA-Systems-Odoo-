<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_zone_list" model="ir.ui.view">
        <field name="name">ecoflow.zone.list</field>
        <field name="model">ecoflow.zone</field>
        <field name="arch" type="xml">
            <list string="Service Zones">
                <field name="code"/>
                <field name="name"/>
                <field name="depot_id"/>
            </list>
        </field>
    </record>

    <record id="view_zone_form" model="ir.ui.view">
        <field name="name">ecoflow.zone.form</field>
        <field name="model">ecoflow.zone</field>
        <field name="arch" type="xml">
            <form string="Service Zone">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="depot_id"/>
                        <field name="active"/>
                    </group>
                    <field name="note" placeholder="Notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_zone" model="ir.actions.act_window">
        <field name="name">Service Zones</field>
        <field name="res_model">ecoflow.zone</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
