<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_bin_list" model="ir.ui.view">
        <field name="name">ecoflow.bin.list</field>
        <field name="model">ecoflow.bin</field>
        <field name="arch" type="xml">
            <list string="Bins">
                <field name="name"/>
                <field name="rfid_tag"/>
                <field name="bin_type"/>
                <field name="capacity_l"/>
                <field name="waste_stream_id"/>
                <field name="site_id"/>
                <field name="zone_id"/>
                <field name="fill_level" widget="progressbar"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'in_service'"
                       decoration-warning="status == 'maintenance'"
                       decoration-muted="status == 'retired'"/>
            </list>
        </field>
    </record>

    <record id="view_bin_form" model="ir.ui.view">
        <field name="name">ecoflow.bin.form</field>
        <field name="model">ecoflow.bin</field>
        <field name="arch" type="xml">
            <form string="Bin">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="rfid_tag"/>
                            <field name="serial"/>
                            <field name="bin_type"/>
                            <field name="capacity_l"/>
                        </group>
                        <group>
                            <field name="waste_stream_id"/>
                            <field name="site_id"/>
                            <field name="zone_id"/>
                            <field name="status"/>
                            <field name="fill_level" widget="progressbar"/>
                            <field name="last_serviced"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_bin_search" model="ir.ui.view">
        <field name="name">ecoflow.bin.search</field>
        <field name="model">ecoflow.bin</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="rfid_tag"/>
                <field name="site_id"/>
                <field name="zone_id"/>
                <filter name="in_service" string="In Service" domain="[('status','=','in_service')]"/>
                <filter name="maintenance" string="Maintenance" domain="[('status','=','maintenance')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_zone" string="Zone" context="{'group_by':'zone_id'}"/>
                    <filter name="group_stream" string="Stream" context="{'group_by':'waste_stream_id'}"/>
                    <filter name="group_status" string="Status" context="{'group_by':'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_bin" model="ir.actions.act_window">
        <field name="name">Bins &amp; Containers</field>
        <field name="res_model">ecoflow.bin</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
