<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_waste_code_list" model="ir.ui.view">
        <field name="name">ecoflow.waste.code.list</field>
        <field name="model">ecoflow.waste.code</field>
        <field name="arch" type="xml">
            <list string="Waste Codes">
                <field name="code"/>
                <field name="name"/>
                <field name="regulator"/>
                <field name="waste_stream_id"/>
                <field name="hazardous"/>
            </list>
        </field>
    </record>

    <record id="view_waste_code_form" model="ir.ui.view">
        <field name="name">ecoflow.waste.code.form</field>
        <field name="model">ecoflow.waste.code</field>
        <field name="arch" type="xml">
            <form string="Waste Code">
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="regulator"/>
                        </group>
                        <group>
                            <field name="waste_stream_id"/>
                            <field name="hazardous"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_waste_code" model="ir.actions.act_window">
        <field name="name">Waste Codes</field>
        <field name="res_model">ecoflow.waste.code</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
