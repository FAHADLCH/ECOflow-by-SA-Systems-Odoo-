<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_service_order_form_routing" model="ir.ui.view">
        <field name="name">ecoflow.service.order.form.routing</field>
        <field name="model">ecoflow.service.order</field>
        <field name="inherit_id" ref="ecoflow_collection.view_service_order_form"/>
        <field name="arch" type="xml">
            <field name="event_id" position="after">
                <field name="route_id"/>
                <field name="route_stop_id"/>
            </field>
        </field>
    </record>

    <record id="view_service_order_list_routing" model="ir.ui.view">
        <field name="name">ecoflow.service.order.list.routing</field>
        <field name="model">ecoflow.service.order</field>
        <field name="inherit_id" ref="ecoflow_collection.view_service_order_list"/>
        <field name="arch" type="xml">
            <field name="bin_id" position="after">
                <field name="route_id" optional="show"/>
            </field>
        </field>
    </record>
</odoo>
