[options]
addons_path = /mnt/extra-addons,/usr/lib/python3/dist-packages/odoo/addons
data_dir = /var/lib/odoo

; Master password for database-management operations. CHANGE THIS.
admin_passwd = CHANGE_ME

; Database connection. Matches the docker-compose 'db' service by default.
db_host = db
db_port = 5432
db_user = odoo
db_password = CHANGE_ME

; Show only ECOFLOW + dependencies on first run via the Apps menu.
; Remove the line below to see the full app list.
; dbfilter = ^ecoflow$

list_db = True
without_demo = False
log_level = info
xmlrpc_port = 8069
proxy_mode = True
