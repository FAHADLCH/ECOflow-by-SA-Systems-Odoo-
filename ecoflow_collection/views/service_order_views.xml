<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_service_order_list" model="ir.ui.view">
        <field name="name">ecoflow.service.order.list</field>
        <field name="model">ecoflow.service.order</field>
        <field name="arch" type="xml">
            <list string="Service Orders" decoration-success="state == 'done'"
                  decoration-danger="state == 'missed'" decoration-muted="state == 'cancel'">
                <field name="name"/>
                <field name="scheduled_date"/>
                <field name="site_id"/>
                <field name="service_id"/>
                <field name="zone_id"/>
                <field name="bin_id"/>
                <field name="priority" widget="priority"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_service_order_form" model="ir.ui.view">
        <field name="name">ecoflow.service.order.form</field>
        <field name="model">ecoflow.service.order</field>
        <field name="arch" type="xml">
            <form string="Service Order">
                <header>
                    <button name="action_schedule" string="Schedule" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_mark_missed" string="Mark Missed" type="object"
                            invisible="state not in ('scheduled','assigned')"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('done','cancel')"/>
                    <button name="action_reset" string="Reset to Draft" type="object"
                            invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,scheduled,assigned,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="site_id"/>
                            <field name="service_id"/>
                            <field name="bin_id"/>
                        </group>
                        <group>
                            <field name="scheduled_date"/>
                            <field name="zone_id"/>
                            <field name="priority"/>
                            <field name="event_id"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_service_order_search" model="ir.ui.view">
        <field name="name">ecoflow.service.order.search</field>
        <field name="model">ecoflow.service.order</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="site_id"/>
                <field name="service_id"/>
                <field name="zone_id"/>
                <filter name="scheduled" string="Scheduled" domain="[('state','=','scheduled')]"/>
                <filter name="done" string="Serviced" domain="[('state','=','done')]"/>
                <filter name="missed" string="Missed" domain="[('state','=','missed')]"/>
                <separator/>
                <filter name="today" string="Today"
                        domain="[('scheduled_date','=',context_today().strftime('%Y-%m-%d'))]"/>
                <group name="group_by">
                    <filter name="group_zone" string="Zone" context="{'group_by':'zone_id'}"/>
                    <filter name="group_state" string="Status" context="{'group_by':'state'}"/>
                    <filter name="group_date" string="Scheduled" context="{'group_by':'scheduled_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_service_order" model="ir.actions.act_window">
        <field name="name">Service Orders</field>
        <field name="res_model">ecoflow.service.order</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
