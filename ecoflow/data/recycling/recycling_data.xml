<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_weigh_ticket" model="ir.sequence">
            <field name="name">ECOFLOW Weigh Ticket</field>
            <field name="code">ecoflow.weigh.ticket</field>
            <field name="prefix">WT/%(year)s/</field>
            <field name="padding">5</field>
        </record>
        <record id="seq_process_batch" model="ir.sequence">
            <field name="name">ECOFLOW Process Batch</field>
            <field name="code">ecoflow.process.batch</field>
            <field name="prefix">PB/%(year)s/</field>
            <field name="padding">4</field>
        </record>
    </data>
</odoo>
