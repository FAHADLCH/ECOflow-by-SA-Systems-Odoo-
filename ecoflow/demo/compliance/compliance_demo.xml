<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="facility_compliance_demo" model="res.partner">
            <field name="name">Regional Treatment Facility</field>
            <field name="is_company" eval="True"/>
            <field name="city">Metro City</field>
        </record>

        <record id="permit_op_demo" model="ecoflow.permit">
            <field name="name">OP-2026-001</field>
            <field name="permit_type">operating</field>
            <field name="holder_id" ref="ecoflow.site_acme"/>
            <field name="scope">Metro-wide collection &amp; transport</field>
            <field name="valid_from">2026-01-01</field>
            <field name="valid_to">2026-12-31</field>
        </record>
        <record id="permit_transport_demo" model="ecoflow.permit">
            <field name="name">TR-2026-014</field>
            <field name="permit_type">transport</field>
            <field name="holder_id" ref="ecoflow.site_acme"/>
            <field name="scope">Hazardous waste transport</field>
            <field name="valid_from">2026-01-01</field>
            <field name="valid_to">2026-07-15</field>
        </record>

        <record id="manifest_demo_1" model="ecoflow.manifest">
            <field name="generator_id" ref="ecoflow.site_acme"/>
            <field name="facility_id" ref="facility_compliance_demo"/>
            <field name="waste_code_id" ref="code_150106"/>
            <field name="state">draft</field>
        </record>
        <record id="manifest_demo_line_1" model="ecoflow.manifest.line">
            <field name="manifest_id" ref="manifest_demo_1"/>
            <field name="waste_stream_id" ref="ecoflow.stream_recycling"/>
            <field name="qty_kg">1100</field>
            <field name="container_count">1</field>
        </record>
    </data>
</odoo>
