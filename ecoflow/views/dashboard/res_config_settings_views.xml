<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_ecoflow" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.ecoflow</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="ECOFLOW" string="ECOFLOW" name="ecoflow"
                     logo="/ecoflow/static/src/img/icon.png">
                    <block title="Operational Thresholds"
                           name="ecoflow_thresholds_setting">
                        <setting string="Mass Balance Tolerance"
                                 help="Allowed deviation between process batch input and recovered + residual output.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <field name="ecoflow_mass_balance_tolerance"
                                           class="o_light_label" style="width: 6rem;"/>
                                    <span class="ms-2">fraction (0.02 = 2%)</span>
                                </div>
                            </div>
                        </setting>
                        <setting string="Permit Expiry Window"
                                 help="A permit is flagged 'Expiring Soon' within this many days of its expiry date.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <field name="ecoflow_permit_expiry_days"
                                           class="o_light_label" style="width: 6rem;"/>
                                    <span class="ms-2">days</span>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="Performance Targets" name="ecoflow_targets_setting">
                        <setting string="Target Diversion Rate"
                                 help="Organisation-wide diversion target used to colour the cockpit diversion KPI.">
                            <div class="content-group">
                                <div class="row mt8">
                                    <field name="ecoflow_target_diversion_rate"
                                           class="o_light_label" style="width: 6rem;"/>
                                    <span class="ms-2">%</span>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_ecoflow_config_settings" model="ir.actions.act_window">
        <field name="name">ECOFLOW Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="context">{'module': 'ecoflow'}</field>
    </record>
</odoo>
