<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_service_list" model="ir.ui.view">
        <field name="name">ecoflow.service.list</field>
        <field name="model">ecoflow.service</field>
        <field name="arch" type="xml">
            <list string="Services">
                <field name="code"/>
                <field name="name"/>
                <field name="waste_stream_id"/>
                <field name="container_type"/>
                <field name="billing_method"/>
                <field name="unit_price"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="sla_hours"/>
            </list>
        </field>
    </record>

    <record id="view_service_form" model="ir.ui.view">
        <field name="name">ecoflow.service.form</field>
        <field name="model">ecoflow.service</field>
        <field name="arch" type="xml">
            <form string="Service">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="waste_stream_id"/>
                            <field name="container_type"/>
                        </group>
                        <group>
                            <field name="billing_method"/>
                            <field name="unit_price"/>
                            <field name="currency_id"/>
                            <field name="sla_hours"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_service" model="ir.actions.act_window">
        <field name="name">Services</field>
        <field name="res_model">ecoflow.service</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
