<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_manifest" model="ir.sequence">
            <field name="name">ECOFLOW Manifest</field>
            <field name="code">ecoflow.manifest</field>
            <field name="prefix">MAN/%(year)s/</field>
            <field name="padding">5</field>
        </record>

        <!-- Sample regulatory waste codes (illustrative EWC-style) -->
        <record id="code_200301" model="ecoflow.waste.code">
            <field name="name">Mixed municipal waste</field>
            <field name="code">20 03 01</field>
            <field name="regulator">EWC</field>
            <field name="hazardous" eval="False"/>
            <field name="waste_stream_id" ref="ecoflow_base.stream_msw"/>
        </record>
        <record id="code_150106" model="ecoflow.waste.code">
            <field name="name">Mixed packaging</field>
            <field name="code">15 01 06</field>
            <field name="regulator">EWC</field>
            <field name="hazardous" eval="False"/>
            <field name="waste_stream_id" ref="ecoflow_base.stream_recycling"/>
        </record>
        <record id="code_200201" model="ecoflow.waste.code">
            <field name="name">Biodegradable waste</field>
            <field name="code">20 02 01</field>
            <field name="regulator">EWC</field>
            <field name="hazardous" eval="False"/>
            <field name="waste_stream_id" ref="ecoflow_base.stream_organics"/>
        </record>
        <record id="code_200135" model="ecoflow.waste.code">
            <field name="name">Discarded electrical equipment (hazardous components)</field>
            <field name="code">20 01 35*</field>
            <field name="regulator">EWC</field>
            <field name="hazardous" eval="True"/>
            <field name="waste_stream_id" ref="ecoflow_base.stream_ewaste"/>
        </record>

        <!-- Permit expiry cron -->
        <record id="cron_permit_expiry" model="ir.cron">
            <field name="name">ECOFLOW: Check Permit Expiry</field>
            <field name="model_id" ref="model_ecoflow_permit"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_expiry()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
