<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_permit_list" model="ir.ui.view">
        <field name="name">ecoflow.permit.list</field>
        <field name="model">ecoflow.permit</field>
        <field name="arch" type="xml">
            <list string="Permits" decoration-danger="state == 'expired'"
                  decoration-warning="state == 'expiring'">
                <field name="name"/>
                <field name="permit_type"/>
                <field name="holder_id"/>
                <field name="vehicle_id"/>
                <field name="valid_from"/>
                <field name="valid_to"/>
                <field name="days_to_expiry"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_permit_form" model="ir.ui.view">
        <field name="name">ecoflow.permit.form</field>
        <field name="model">ecoflow.permit</field>
        <field name="arch" type="xml">
            <form string="Permit">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="permit_type"/>
                            <field name="holder_id"/>
                            <field name="vehicle_id"/>
                            <field name="scope"/>
                        </group>
                        <group>
                            <field name="valid_from"/>
                            <field name="valid_to"/>
                            <field name="days_to_expiry"/>
                            <field name="state"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_permit_search" model="ir.ui.view">
        <field name="name">ecoflow.permit.search</field>
        <field name="model">ecoflow.permit</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="holder_id"/>
                <filter name="expiring" string="Expiring Soon" domain="[('state','=','expiring')]"/>
                <filter name="expired" string="Expired" domain="[('state','=','expired')]"/>
                <group name="group_by">
                    <filter name="group_type" string="Type" context="{'group_by':'permit_type'}"/>
                    <filter name="group_state" string="Status" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_permit" model="ir.actions.act_window">
        <field name="name">Permits</field>
        <field name="res_model">ecoflow.permit</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
