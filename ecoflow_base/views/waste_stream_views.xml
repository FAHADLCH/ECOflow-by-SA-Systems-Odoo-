<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_waste_stream_list" model="ir.ui.view">
        <field name="name">ecoflow.waste.stream.list</field>
        <field name="model">ecoflow.waste.stream</field>
        <field name="arch" type="xml">
            <list string="Waste Streams">
                <field name="code"/>
                <field name="name"/>
                <field name="hazard_class"/>
                <field name="recyclable"/>
                <field name="default_waste_code"/>
            </list>
        </field>
    </record>

    <record id="view_waste_stream_form" model="ir.ui.view">
        <field name="name">ecoflow.waste.stream.form</field>
        <field name="model">ecoflow.waste.stream</field>
        <field name="arch" type="xml">
            <form string="Waste Stream">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="hazard_class"/>
                        </group>
                        <group>
                            <field name="recyclable"/>
                            <field name="default_waste_code"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="note" placeholder="Notes..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_waste_stream" model="ir.actions.act_window">
        <field name="name">Waste Streams</field>
        <field name="res_model">ecoflow.waste.stream</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
